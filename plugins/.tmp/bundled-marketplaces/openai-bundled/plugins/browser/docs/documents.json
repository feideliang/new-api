[
  {
    "mode": "included",
    "name": "browser-safety"
  },
  {
    "mode": "included",
    "name": "visibility",
    "when": {
      "requiredBrowserCapabilities": [
        "visibility"
      ]
    }
  },
  {
    "mode": "included",
    "name": "session-naming",
    "when": {
      "browserTypes": [
        "extension"
      ],
      "requiredApiMembers": [
        "Browser.nameSession"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-claiming-chrome",
    "when": {
      "browserTypes": [
        "extension"
      ],
      "requiredApiMembers": [
        "BrowserUser.openTabs",
        "BrowserUser.claimTab"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-claiming-iab",
    "when": {
      "browserTypes": [
        "iab"
      ],
      "requiredApiMembers": [
        "BrowserUser.openTabs",
        "BrowserUser.claimTab"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-cleanup-chrome",
    "when": {
      "browserTypes": [
        "extension"
      ],
      "requiredApiMembers": [
        "Tabs.finalize"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-cleanup-chrome-internal",
    "when": {
      "browserTypes": [
        "extension"
      ],
      "requiredApiMembers": [
        "Tab.markDeliverable",
        "Tab.markHandoff"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-cleanup-iab",
    "when": {
      "browserTypes": [
        "iab"
      ],
      "requiredApiMembers": [
        "Tabs.finalize"
      ]
    }
  },
  {
    "mode": "included",
    "name": "tab-cleanup-iab-internal",
    "when": {
      "browserTypes": [
        "iab"
      ],
      "requiredApiMembers": [
        "Tab.markDeliverable",
        "Tab.markHandoff"
      ]
    }
  },
  {
    "mode": "included",
    "name": "all-tabs-cleanup",
    "when": {
      "browserTypes": [
        "iab"
      ],
      "requiredApiMembers": [
        "BrowserUser.openTabs",
        "BrowserUser.claimTab",
        "Tab.close",
        "Tabs.list"
      ]
    }
  },
  {
    "mode": "included",
    "name": "browser-control-interruption"
  },
  {
    "mode": "included",
    "name": "api-use-behavior"
  },
  {
    "mode": "included",
    "name": "playwright",
    "when": {
      "requiredApiMembers": [
        "Tab.playwright"
      ]
    }
  },
  {
    "description": "read before asking the user for browser confirmation",
    "mode": "lookup",
    "name": "confirmations"
  },
  {
    "description": "read when a selected browser fails while interacting with a page",
    "mode": "lookup",
    "name": "browser-troubleshooting"
  },
  {
    "description": "read before uploading files through a webpage",
    "mode": "lookup",
    "name": "file-uploads",
    "when": {
      "requiredApiMembers": [
        "PlaywrightAPI.waitForEvent",
        "PlaywrightFileChooser.setFiles"
      ]
    }
  },
  {
    "description": "read when a Chrome file upload fails",
    "mode": "lookup",
    "name": "chrome-file-upload-troubleshooting",
    "when": {
      "browserTypes": [
        "extension"
      ]
    }
  },
  {
    "description": "read when the user asks for screenshots",
    "mode": "lookup",
    "name": "screenshots"
  }
]
